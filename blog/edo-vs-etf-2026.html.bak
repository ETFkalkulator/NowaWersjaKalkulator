    .dark .article-prose .table-scroll::after {
      background: linear-gradient(to left, rgba(15, 23, 42, 0.92), rgba(15, 23, 42, 0));
    }

    .article-prose .table-scroll.can-scroll-left::before,
    .article-prose .table-scroll.can-scroll-right::after {
