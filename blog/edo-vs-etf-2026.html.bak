  <script>
    document.addEventListener("DOMContentLoaded", function () {
      document.querySelectorAll(".article-prose table").forEach(function (table) {
        var parent = table.parentElement;
        if (!parent) return;

        var wrap = null;
        if (parent.classList.contains("table-scroll") || parent.classList.contains("overflow-x-auto")) {
          wrap = parent;
          wrap.classList.add("table-scroll");
        } else {
          wrap = document.createElement("div");
          wrap.className = "table-scroll";
          parent.insertBefore(wrap, table);
          wrap.appendChild(table);
        }

        if (!wrap.hasAttribute("role")) wrap.setAttribute("role", "region");
        if (!wrap.hasAttribute("tabindex")) wrap.setAttribute("tabindex", "0");
        if (!wrap.hasAttribute("aria-label")) {
          wrap.setAttribute("aria-label", "Tabela - przewiń poziomo, aby zobaczyć wszystkie kolumny");
        }

        var hint = wrap.nextElementSibling;
        if (!hint || !hint.classList || !hint.classList.contains("table-scroll-hint")) {
          hint = document.createElement("p");
          hint.className = "table-scroll-hint";
          hint.setAttribute("aria-hidden", "true");
          hint.textContent = "Przesuń tabelę w bok";
          wrap.insertAdjacentElement("afterend", hint);
        }

        var updateTableUi = function () {
          var hasOverflow = wrap.scrollWidth > wrap.clientWidth + 2;
          var canScrollLeft = wrap.scrollLeft > 2;
          var canScrollRight = wrap.scrollLeft < (wrap.scrollWidth - wrap.clientWidth - 2);

          wrap.classList.toggle("has-overflow", hasOverflow);
          wrap.classList.toggle("can-scroll-left", hasOverflow && canScrollLeft);
          wrap.classList.toggle("can-scroll-right", hasOverflow && canScrollRight);

          var showHint = hasOverflow && canScrollRight && window.innerWidth <= 768;
          hint.hidden = !showHint;
          hint.style.display = showHint ? "flex" : "none";
        };

        if (wrap.dataset.tableEnhanced !== "1") {
          wrap.dataset.tableEnhanced = "1";
          wrap.addEventListener("scroll", updateTableUi, { passive: true });
          window.addEventListener("resize", updateTableUi);
          if (window.ResizeObserver) {
            var ro = new ResizeObserver(updateTableUi);
            ro.observe(wrap);
          }
        }

        requestAnimationFrame(updateTableUi);
      });
    });
  </script>
  <script>
    const bar = document.getElementById('reading-progress');
    const article = document.getElementById('main');
    const mobileBar = document.getElementById('reading-progress-mobile');
    const pctLabel = document.getElementById('reading-pct');
    function updateProgress() {
      if (!bar || !article) return;
      const rect = article.getBoundingClientRect();
      const total = article.offsetHeight - window.innerHeight;
      const scrolled = Math.max(0, -rect.top);
      const pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
      bar.style.width = pct + '%';
      if (mobileBar) mobileBar.style.width = pct + '%';
      if (pctLabel) pctLabel.textContent = Math.round(pct) + '%';
    }
    const headings = document.querySelectorAll('article h2[id]');
    const tocLinks = document.querySelectorAll('.sidebar-toc a');
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(a => a.classList.remove('toc-active'));
          const active = document.querySelector('.sidebar-toc a[href="#' + entry.target.id + '"]');
          if (active) active.classList.add('toc-active');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    headings.forEach(h => observer.observe(h));
    document.querySelectorAll('.faq-item summary').forEach(summary => {
      if (summary.querySelector('.expand-icon')) return;
      const icon = document.createElement('span');
      icon.className = 'material-symbols-outlined expand-icon';
      icon.textContent = 'expand_more';
      summary.appendChild(icon);
    });
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  </script>
  <script defer>
    function przelaczTryb() {
      const html = document.documentElement;
      const isDark = html.classList.contains("dark");

      if (isDark) {
        html.classList.remove("dark", "dark-mode");
        html.classList.add("light", "light-mode");
        localStorage.setItem("etf-tryb", "jasny");
      } else {
        html.classList.add("dark", "dark-mode");
        html.classList.remove("light", "light-mode");
        localStorage.setItem("etf-tryb", "ciemny");
      }

      const d = html.classList.contains("dark");
      const m = document.getElementById("meta-theme-color");
      if (m) m.content = d ? "#0f172a" : "#f8fafc";
    }

    (function () {
      const html = document.documentElement;
      const saved = localStorage.getItem("etf-tryb");
      const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;

      if (saved === "ciemny" || (!saved && systemDark)) {
        html.classList.add("dark", "dark-mode");
        html.classList.remove("light", "light-mode");
      } else {
        html.classList.add("light", "light-mode");
        html.classList.remove("dark", "dark-mode");
      }

      const m = document.getElementById("meta-theme-color");
      if (m) m.content = html.classList.contains("dark") ? "#0f172a" : "#f8fafc";
    })();
  </script>
  <script src="https://www.google.com/recaptcha/api.js" defer></script>
  <script src="https://groot.mailerlite.com/js/w/webforms.min.js?v95037e5bac78f29ed026832ca21a7c7b"
    type="text/javascript" defer></script>
  <!-- Cookie Consent -->
  <script src="../js/cookie-consent.js" defer></script>
</body>

</html>


