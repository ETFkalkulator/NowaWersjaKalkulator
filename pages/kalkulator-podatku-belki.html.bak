  <!-- LOGIKA KALKULATORA -->
  <script defer>
    // ============================================================
    // KALKULATOR PODATKU BELKI — logika
    // ============================================================

    let aktywnyTrybKalk = 'prosty';
    let belkiChart = null;

    // --- Przełącznik trybu ---
    function przelaczTrybKalk(tryb) {
      aktywnyTrybKalk = tryb;

      const tabProsty = document.getElementById('tab-prosty');
      const tabSym = document.getElementById('tab-symulacja');
      const formProsty = document.getElementById('form-prosty');
      const formSym = document.getElementById('form-symulacja');
      const wynikProsty = document.getElementById('wyniki-prosty');
      const wynikSym = document.getElementById('wyniki-symulacja');

      if (tryb === 'prosty') {
        tabProsty.classList.add('aktywna');
        tabSym.classList.remove('aktywna');
        tabProsty.setAttribute('aria-pressed', 'true');
        tabSym.setAttribute('aria-pressed', 'false');
        formProsty.classList.remove('hidden');
        formSym.classList.add('hidden');
        wynikProsty.classList.remove('hidden');
        wynikSym.classList.add('hidden');
        obliczProsty();
      } else {
        tabSym.classList.add('aktywna');
        tabProsty.classList.remove('aktywna');
        tabSym.setAttribute('aria-pressed', 'true');
        tabProsty.setAttribute('aria-pressed', 'false');
        formSym.classList.remove('hidden');
        formProsty.classList.add('hidden');
        wynikSym.classList.remove('hidden');
        wynikProsty.classList.add('hidden');
        obliczSymulacja();
      }
    }

    // --- Pomocnicze ---
    function parsePLN(id) {
      const el = document.getElementById(id);
      if (!el) return 0;
      const v = parseFloat(el.value.replace(/\s/g, '').replace(',', '.'));
      return isNaN(v) || v < 0 ? 0 : v;
    }

    function fmt(v) {
      return new Intl.NumberFormat('pl-PL', {
        style: 'currency',
        currency: 'PLN',
        maximumFractionDigits: 2,
        minimumFractionDigits: 2
      }).format(v);
    }

    function setEl(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }

    // --- TRYB PROSTY ---
    function obliczProsty() {
      const koncowa = parsePLN('input-wartosc-koncowa');
      const wplaty = parsePLN('input-suma-wplat');
      const zysk = Math.max(0, koncowa - wplaty);
      const podatek = zysk * 0.19;
      const netto = zysk - podatek;

      setEl('wynik-zysk-brutto', fmt(zysk));
      setEl('wynik-podatek-prosty', fmt(podatek));
      setEl('wynik-zysk-netto', fmt(netto));
      setEl('wynik-ike-oszczednosc', fmt(podatek));
      setEl('pasek-label-brutto', fmt(zysk));

      // Pasek wizualny
      const nettoPct = zysk > 0 ? 81 : 50;
      const podatekPct = zysk > 0 ? 19 : 50;
      const pasekN = document.getElementById('pasek-netto');
      const pasekP = document.getElementById('pasek-podatek');
      if (pasekN) { pasekN.style.width = nettoPct + '%'; pasekN.querySelector('span').textContent = nettoPct + '%'; }
      if (pasekP) { pasekP.style.width = podatekPct + '%'; pasekP.querySelector('span').textContent = podatekPct + '%'; }
    }

    function ustawPrzyklad(koncowa, wplaty) {
      const ek = document.getElementById('input-wartosc-koncowa');
      const ew = document.getElementById('input-suma-wplat');
      if (ek) ek.value = koncowa;
      if (ew) ew.value = wplaty;
      obliczProsty();
    }

    // --- TRYB SYMULACJI ---
    function ustawStope(val) {
      const el = document.getElementById('input-sim-stopa');
      if (el) { el.value = val; obliczSymulacja(); }
    }

    function obliczSymulacja() {
      const kapital = parsePLN('input-sim-kapital') || 1000;
      const doplata = parsePLN('input-sim-doplata');
      const stopaRaw = parsePLN('input-sim-stopa');
      const stopa = stopaRaw > 0 ? stopaRaw : 7;
      const lataRaw = parseInt((document.getElementById('input-sim-lata') || {}).value) || 15;
      const lata = Math.max(1, Math.min(50, lataRaw));

      const r = stopa / 100;

      const labels = ['Dziś'];
      const dataWplate = [Math.round(kapital)];
      const dataBelki = [Math.round(kapital)];
      const dataIKE = [Math.round(kapital)];

      let saldo = kapital;
      let wplate = kapital;
      const tabelaData = [];

      for (let rok = 1; rok <= lata; rok++) {
        saldo = saldo * (1 + r) + doplata * 12;
        wplate += doplata * 12;

        const zysk = Math.max(0, saldo - wplate);
        const podatek = Math.round(zysk * 0.19);
        const saldonetto = Math.round(saldo - zysk * 0.19);

        labels.push('Rok\u00A0' + rok);
        dataWplate.push(Math.round(wplate));
        dataBelki.push(saldonetto);
        dataIKE.push(Math.round(saldo));

        tabelaData.push({
          rok,
          wplate: Math.round(wplate),
          saldo: Math.round(saldo),
          zysk: Math.round(zysk),
          podatek,
          saldonetto,
          roznica: Math.round(saldo) - saldonetto
        });
      }

      const last = tabelaData[tabelaData.length - 1];
      setEl('wynik-sim-podatek-total', fmt(last.podatek));
      setEl('wynik-sim-belki', fmt(last.saldonetto));
      setEl('wynik-sim-ike', fmt(last.saldo));
      setEl('wynik-sim-roznica', fmt(last.roznica));

      renderSimChart(labels, dataWplate, dataBelki, dataIKE);
      renderSimTabela(tabelaData);
    }

    function renderSimChart(labels, dataWplate, dataBelki, dataIKE) {
      const canvas = document.getElementById('chartBelki');
      if (!canvas || typeof Chart === 'undefined' || !window.ETF || !window.ETF.charts) return;

      const ctx = canvas.getContext('2d');
      if (belkiChart) { belkiChart.destroy(); belkiChart = null; }

      const opts = window.ETF.charts.getBaseOptions();

      belkiChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            window.ETF.charts.createDataset(ctx, 'Wpłacony kapitał', dataWplate, '#8E8E93'),
            window.ETF.charts.createDataset(ctx, 'Z podatkiem Belki', dataBelki, '#1A56A0'),
            window.ETF.charts.createDataset(ctx, 'IKE/IKZE (0% podatku)', dataIKE, '#34C759')
          ]
        },
        options: opts
      });
    }

    function renderSimTabela(data) {
      const tbody = document.getElementById('tabela-sim-body');
      if (!tbody) return;

      tbody.innerHTML = data.map(function(r) {
        return '<tr class="hover:bg-stitch-surface/50 transition-colors">' +
          '<td class="sticky left-0 z-10 bg-stitch-bg dark:bg-slate-950 px-4 py-3.5 text-sm font-bold text-stitch-text whitespace-nowrap shadow-[2px_0_5px_-2px_rgba(0,0,0,0.07)]">' + r.rok + '</td>' +
          '<td class="px-3 py-3.5 text-sm text-stitch-muted text-right whitespace-nowrap">' + fmt(r.wplate) + '</td>' +
          '<td class="px-3 py-3.5 text-sm text-stitch-text font-semibold text-right whitespace-nowrap">' + fmt(r.saldo) + '</td>' +
          '<td class="px-3 py-3.5 text-sm font-semibold text-rose-500 dark:text-rose-400 text-right whitespace-nowrap">−' + fmt(r.podatek) + '</td>' +
          '<td class="px-3 py-3.5 text-sm text-stitch-muted text-right whitespace-nowrap">' + fmt(r.saldonetto) + '</td>' +
          '<td class="px-3 py-3.5 text-sm font-bold text-emerald-600 dark:text-emerald-400 text-right whitespace-nowrap">' + fmt(r.saldo) + '</td>' +
          '</tr>';
      }).join('');
    }

    // --- INICJALIZACJA ---
    document.addEventListener('DOMContentLoaded', function () {
      obliczProsty();

      // Re-render chart on theme change
      window.addEventListener('theme-changed', function () {
        if (aktywnyTrybKalk === 'symulacja') obliczSymulacja();
      });
    });

    // Fallback if DOMContentLoaded already fired
    if (document.readyState !== 'loading') {
      obliczProsty();
    }
  </script>

  <!-- Global Logic -->
  <script defer>
    function przelaczTryb() {
      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      if (isDark) {
        html.classList.remove('dark');
        html.classList.add('light');
        localStorage.setItem('etf-tryb', 'jasny');
      } else {
        html.classList.add('dark');
        html.classList.remove('light');
        localStorage.setItem('etf-tryb', 'ciemny');
      }
      const d = html.classList.contains('dark');
      const m = document.getElementById('meta-theme-color');
      if (m) m.content = d ? '#0f172a' : '#f8fafc';
      window.dispatchEvent(new CustomEvent('theme-changed'));
    }

    (function () {
      const html = document.documentElement;
      const saved = localStorage.getItem('etf-tryb');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'ciemny' || (!saved && systemDark)) {
        html.classList.add('dark');
      }
    })();
  </script>

  <script src="https://www.google.com/recaptcha/api.js" defer></script>
  <script src="https://groot.mailerlite.com/js/w/webforms.min.js?v95037e5bac78f29ed026832ca21a7c7b"
    type="text/javascript" defer></script>
  <script src="../js/cookie-consent.js" defer></script>
</body>

</html>
