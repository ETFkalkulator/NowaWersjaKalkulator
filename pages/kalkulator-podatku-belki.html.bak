  <main id="main" class="pt-20 pb-20 px-6 min-h-screen bg-stitch-bg dark:bg-slate-950 transition-colors duration-300">
    <div class="max-w-7xl mx-auto">
      <div class="print-only hidden">ETFkalkulator.pl — Wydruk wyników kalkulatora podatku Belki</div>

      <!-- HERO / BREADCRUMBS -->
      <div class="mb-12">
        <nav class="flex items-center gap-2 text-xs font-medium text-slate-400 uppercase tracking-widest mb-4">
          <a href="../index.html" class="hover:text-primary transition-colors">ETFkalkulator.pl</a>
          <span aria-hidden="true" class="material-symbols-outlined text-[14px]">chevron_right</span>
          <span class="text-slate-600 dark:text-slate-300">Kalkulator Podatku Belki</span>
        </nav>
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-stitch-text mb-4">
          Kalkulator <span class="text-primary" style="color:#0d7ff2;">Podatku Belki</span>
        </h1>
        <p class="text-lg text-stitch-muted max-w-2xl leading-relaxed">
          Oblicz ile zapłacisz podatku od zysku z ETF, akcji lub obligacji. Sprawdź, ile kapitału tracisz bez IKE/IKZE i
          o ile więcej możesz zaoszczędzić.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- LEWA KOLUMNA: FORMULARZ -->
        <aside class="lg:col-span-4 space-y-6">
          <div
            class="glass-effect p-8 rounded-[2rem] border border-white/50 shadow-stitch-soft shadow-slate-200/50 dark:shadow-none">

            <!-- PRZEŁĄCZNIK TRYBU -->
            <div class="flex gap-1 p-1.5 bg-slate-100 dark:bg-slate-800 rounded-[1rem] mb-8">
              <button id="tab-prosty" type="button" onclick="przelaczTrybKalk('prosty')"
                class="tab-belki aktywna" aria-pressed="true">
                Tryb prosty
              </button>
              <button id="tab-symulacja" type="button" onclick="przelaczTrybKalk('symulacja')"
                class="tab-belki" aria-pressed="false">
                Tryb symulacji
              </button>
            </div>

            <!-- FORMULARZ: TRYB PROSTY -->
            <div id="form-prosty">
              <h3 class="text-lg font-bold text-stitch-text mb-6 flex items-center gap-3">
                <span aria-hidden="true" class="material-symbols-outlined text-primary" style="color:#0d7ff2;">calculate</span>
                Oblicz podatek od zysku
              </h3>
              <div class="space-y-6">

                <!-- Wartość końcowa -->
                <div class="space-y-3">
                  <div class="flex justify-between items-center">
                    <label for="input-wartosc-koncowa"
                      class="text-sm font-bold text-slate-700 dark:text-slate-300 uppercase tracking-wider">
                      Wartość końcowa
                    </label>
                    <span class="text-xs font-bold text-primary dark:text-primary/80 bg-primary/10 dark:bg-primary/20 px-2 py-1 rounded-md" style="color:#0d7ff2;">PLN</span>
                  </div>
                  <input type="text" inputmode="decimal" id="input-wartosc-koncowa"
                    class="w-full h-14 px-5 rounded-stitch bg-stitch-surface border-2 border-slate-100 text-stitch-text text-lg font-bold focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all outline-none"
                    value="30000" autocomplete="off" oninput="obliczProsty()">
                  <p class="text-[11px] text-slate-400 mt-1.5">Kwota, którą otrzymałeś ze sprzedaży (lub aktualna wartość portfela).</p>
                </div>

                <!-- Suma wpłat -->
                <div class="space-y-3">
