                      class="py-2.5 rounded-stitch border border-stitch-border bg-stitch-surface text-[10px] font-bold uppercase tracking-tight text-stitch-muted hover:border-primary/50 transition-all"
                      onclick="ustawPrzyklad(15000,10000)">15k / 10k<br><span class="font-normal lowercase opacity-70">+5 000 zł</span></button>
                    <button type="button"
                      class="py-2.5 rounded-stitch border-2 border-primary/50 bg-primary/5 text-[10px] font-bold uppercase tracking-tight text-primary hover:border-primary transition-all"
                      onclick="ustawPrzyklad(30000,20000)">30k / 20k<br><span class="font-normal lowercase opacity-70">+10 000 zł</span></button>
